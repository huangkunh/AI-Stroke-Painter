{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "ai-stroke-painter",
  "description": "AI Stroke Painter - image to stroke-by-stroke painting playback",
  "public": true,

  "builds": [
    {
      "src": "renderer/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/infer.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "memory": 1024,
        "includeFiles": "model/**,converter/**"
      }
    },
    {
      "src": "api/transform.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30,
        "memory": 512,
        "includeFiles": "converter/**"
      }
    },
    {
      "src": "api/pipeline.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "memory": 1024,
        "includeFiles": "model/**,converter/**"
      }
    }
  ],

  "routes": [
    {
      "src": "/",
      "dest": "/renderer/index.html"
    },
    {
      "src": "/api/infer",
      "dest": "/api/infer.py"
    },
    {
      "src": "/api/transform",
      "dest": "/api/transform.py"
    },
    {
      "src": "/api/pipeline",
      "dest": "/api/pipeline.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],

  "env": {
    "ASP_DEFAULT_MAX_STEPS": "400",
    "ASP_DEFAULT_MODE": "lite",
    "ASP_DEFAULT_BACKGROUND": "#f8ecdb",
    "ASP_API_KEY_REQUIRED": "false"
  },

  "regions": ["sfo1", "iad1", "hnd1", "sin1", "fra1"],

  "headers": [
    {
      "source": "/renderer/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Encoding", "value": "gzip" }
      ]
    },
    {
      "source": "/renderer/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/renderer/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-API-Key" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],

  "functions": {
    "api/infer.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/transform.py": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/pipeline.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
